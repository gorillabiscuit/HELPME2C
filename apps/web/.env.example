# Clerk auth (per ADR-0004). Get keys from https://dashboard.clerk.com.
# Copy this file to apps/web/.env.local (gitignored) and fill in your values.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Post-auth redirect targets. Per the M1 mapping decision, fresh signups go
# straight into the onboarding flow (M4); returning sign-ins land on the
# homepage (becomes the dashboard once content lands).
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
