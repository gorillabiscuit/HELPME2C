# Clerk auth (per ADR-0004). Get keys from https://dashboard.clerk.com.
# Copy this file to apps/web/.env.local (gitignored) and fill in your values.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Post-auth redirect targets. Per the M1 mapping decision, fresh signups go
# straight into the onboarding flow (M4); returning sign-ins land on the
# homepage (becomes the dashboard once content lands).
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Sentry — error tracking + tracing per ADR-0010. EU region per ADR-0012 §1.
# DSN is public-safe (designed to be embedded in browser JS); used by both
# client and server runtimes via the same NEXT_PUBLIC_ env var for simplicity.
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.de.sentry.io/...

# Source map upload — production deploy only. Local dev runs without these and
# the Sentry build plugin silently skips upload.
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# PostHog — product analytics + session replay per ADR-0010. EU region per
# ADR-0012 §1. Project token is public-safe (designed for browser embedding).
# Capture is opt-out by default; consent toggles in the GDPR banner flip it on.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
