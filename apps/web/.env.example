# Clerk auth (per ADR-0004). Get keys from https://dashboard.clerk.com.
# Copy this file to apps/web/.env.local (gitignored) and fill in your values.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Post-auth redirect targets. Per the M1 mapping decision, fresh signups go
# straight into the onboarding flow (M4); returning sign-ins land on the
# homepage (becomes the dashboard once content lands).
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/age-check

# Sentry — error tracking + tracing per ADR-0010. EU region per ADR-0012 §1.
# DSN is public-safe (designed to be embedded in browser JS); used by both
# client and server runtimes via the same NEXT_PUBLIC_ env var for simplicity.
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.de.sentry.io/...

# Source map upload — production deploy only. Local dev runs without these and
# the Sentry build plugin silently skips upload.
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# PostHog — product analytics + session replay per ADR-0010. EU region per
# ADR-0012 §1. Project token is public-safe (designed for browser embedding).
# Capture is opt-out by default; consent toggles in the GDPR banner flip it on.
NEXT_PUBLIC_POSTHOG_KEY=phc_qcgwPjgtECdZBYv4Y3u4wmvzrxscEjUj7Sy5UXNArsWV
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Neon Postgres (per ADR-0005 + ADR-0019). EU Frankfurt region per ADR-0012 §1.
# Use the pooler host (not the direct host) for serverless compatibility.
# Get from: Neon console → project → Connection details → Pooler.
# TMDB — content metadata + streaming availability per ADR-0009.
# Read Access Token (v4 bearer token) — preferred over the v3 API key.
# Get from: themoviedb.org → Settings → API.
TMDB_READ_ACCESS_TOKEN=eyJ...
TMDB_API_KEY=...

# Clerk webhook signing secret. Generated when you create the
# /api/webhook/clerk endpoint in Clerk Dashboard → Webhooks. Used by svix
# to verify incoming webhook signatures so we don't trust arbitrary callers
# at the public webhook URL. Format: `whsec_…`.
CLERK_WEBHOOK_SECRET=whsec_...

# Inngest — job orchestration per ADR-0007.
# Get from: app.inngest.com → your app → Manage → Signing Key / Event Key.
# Leave blank for local dev with `npx inngest-cli@latest dev` (dev server handles auth).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Forces the SDK into dev mode against the local Inngest dev server. Required
# when running `npx inngest-cli@latest dev` locally — without it the SDK
# defaults to cloud mode and /api/inngest 500s with "no signing key found".
# Leave unset (or set to 0) in production.
INNGEST_DEV=1

DATABASE_URL=postgresql://neondb_owner:...@ep-...-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Direct (unpooled) connection — drizzle-kit uses this for migrations.
# Get from: Neon console → Connection details → Direct connection.
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:...@ep-....c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require
