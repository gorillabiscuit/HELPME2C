{
  "name": "helpme2c",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-medium recommendation engine for TV and anime — workspace root.",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "preflight": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.10.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
